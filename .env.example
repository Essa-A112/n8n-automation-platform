N8N_ENCRYPTION_KEY=CHANGEME_FAKE_EXAMPLE_VALUE_DO_NOT_USE# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Reference for the environment variables you must set in Render
#
# DO NOT put real values in this file. Set them in the Render dashboard under:
#   Your Service → Environment → Add Environment Variable
#
# Variables marked [AUTO] are filled automatically from the database — skip them.
# Variables marked [REQUIRED] must be set by you before n8n will work correctly.
# Variables marked [OPTIONAL] have safe defaults and can be left alone.
# ─────────────────────────────────────────────────────────────────────────────


# ── [REQUIRED] Encryption key ─────────────────────────────────────────────────
# Used to encrypt every credential you save (Xero, QuickBooks, Gmail, etc.)
# Generate once with this command:   openssl rand -hex 32
# WARNING: If you ever change this value, ALL saved credentials will stop working.
# Store a copy somewhere safe (e.g. a password manager).
N8N_ENCRYPTION_KEY=CHANGEME_FAKE_EXAMPLE_VALUE_DO_NOT_USE


# ── [REQUIRED] Public URL ─────────────────────────────────────────────────────
# Set both of these to your Render service URL after your first deploy.
# Example (replace with your actual Render URL):
#   N8N_HOST=n8n-automation.onrender.com
#   WEBHOOK_URL=https://n8n-automation.onrender.com
N8N_HOST=your-app-name.onrender.com
WEBHOOK_URL=https://your-app-name.onrender.com


# ── [AUTO] Database — filled automatically from the Render Postgres service ───
# You do not need to set these; render.yaml links them for you.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=      # auto
DB_POSTGRESDB_PORT=      # auto
DB_POSTGRESDB_DATABASE=  # auto
DB_POSTGRESDB_USER=      # auto
DB_POSTGRESDB_PASSWORD=  # auto
DB_POSTGRESDB_SSL=true


# ── [AUTO] n8n port & protocol — set by render.yaml ──────────────────────────
N8N_PORT=5678
N8N_PROTOCOL=https
NODE_ENV=production


# ── [AUTO] Timezone ───────────────────────────────────────────────────────────
GENERIC_TIMEZONE=Europe/London
TZ=Europe/London


# ── [OPTIONAL] Execution history ─────────────────────────────────────────────
# How long to keep a log of past workflow runs (in hours). 720 = 30 days.
EXECUTIONS_DATA_MAX_AGE=720

# Save logs for failed runs (useful for debugging). "all" or "none".
EXECUTIONS_DATA_SAVE_ON_ERROR=all

# Save logs for successful runs. "none" saves database space; "all" keeps full history.
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
